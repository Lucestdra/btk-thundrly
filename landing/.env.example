# ─── Resend (iletişim formu mail gönderimi) ───────────────────────
# https://resend.com/api-keys adresinden API anahtarı al.
RESEND_API_KEY=

# Doğrulanmış bir domain'in varsa "İletişim <iletisim@thundrly.com>" gibi.
# Yoksa default 'Thundrly <onboarding@resend.dev>' kullanılır
# (yalnızca aynı Resend hesabına kayıtlı adreslere mail gönderebilir).
MAIL_FROM=

# Mesajların ulaşacağı adres. Boş bırakırsan default
# agdemirhalim4@gmail.com kullanılır.
CONTACT_TO=

# ─── Site ────────────────────────────────────────────────────────
# OpenGraph + sitemap için canonical origin.
NEXT_PUBLIC_SITE_URL=https://thundrly.com
