{
  "manifest_version": 3,
  "name": "Thundrly",
  "short_name": "Thundrly",
  "version": "0.1.0",
  "description": "Satın almadan önce 5 saniyelik akıllı kontrol — Türk e-ticaret için AI alışveriş asistanı.",
  "action": {
    "default_title": "Thundrly",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.trendyol.com/*",
        "*://*.hepsiburada.com/*",
        "*://*.n11.com/*",
        "*://*.amazon.com.tr/*",
        "*://*.ciceksepeti.com/*",
        "*://*.mediamarkt.com.tr/*",
        "*://*.teknosa.com/*",
        "*://*.vatanbilgisayar.com/*",
        "*://*.boyner.com.tr/*",
        "*://*.lcwaikiki.com/*",
        "*://*.defacto.com.tr/*",
        "*://*.modanisa.com/*",
        "*://*.a101.com.tr/*",
        "*://*.migros.com.tr/*",
        "*://*.carrefoursa.com/*",
        "*://*.beymen.com/*",
        "*://*.pazarama.com/*",
        "*://*.pttavm.com/*",
        "*://*.tchibo.com.tr/*",
        "*://*.decathlon.com.tr/*",
        "*://*.ikea.com.tr/*"
      ],
      "js": ["src/contentScript.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/contentScript.ts"],
      "run_at": "document_idle",
      "include_globs": ["*demo-product.html*"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["public/demo-product.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "https://api.thundrly.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.trendyol.com/*",
    "https://*.hepsiburada.com/*",
    "https://*.n11.com/*",
    "https://*.amazon.com.tr/*",
    "https://*.ciceksepeti.com/*",
    "https://*.mediamarkt.com.tr/*",
    "https://*.teknosa.com/*",
    "https://*.vatanbilgisayar.com/*",
    "https://*.boyner.com.tr/*",
    "https://*.lcwaikiki.com/*",
    "https://*.defacto.com.tr/*",
    "https://*.modanisa.com/*",
    "https://*.a101.com.tr/*",
    "https://*.migros.com.tr/*",
    "https://*.carrefoursa.com/*",
    "https://*.beymen.com/*",
    "https://*.pazarama.com/*",
    "https://*.pttavm.com/*",
    "https://*.tchibo.com.tr/*",
    "https://*.decathlon.com.tr/*",
    "https://*.ikea.com.tr/*"
  ],
  "permissions": ["storage"]
}
