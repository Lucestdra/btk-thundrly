# Tartı backend configuration.
# Copy to `.env` and fill in for local overrides; nothing in this file is
# required for the default SQLite-backed dev setup.

# --- Database ---
# Default: file-based SQLite at app/data/observations.db (no setup needed).
# For Postgres in prod:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/tarti
DATABASE_URL=

# --- CORS ---
# Comma-separated list. Defaults to localhost:3000 + 127.0.0.1:3000.
# chrome-extension://* is always allowed via regex.
ALLOWED_ORIGINS=

# --- Rate limiting (slowapi) ---
# Default: in-memory (single-instance only).
# For multi-instance, use Redis:
#   RATELIMIT_STORAGE_URI=redis://localhost:6379
RATELIMIT_STORAGE_URI=

# --- Gemini (review_agent) ---
# Without a key the review_agent uses its deterministic heuristic path
# (same fallback we exercise in tests). With a key set, the agent calls
# Gemini with a Pydantic-validated JSON response schema.
#   Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default: gemini-1.5-flash (cheap + fast). Examples of overrides:
#   GEMINI_MODEL=gemini-1.5-pro
#   GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL=

# --- Gemini response cache ---
# In-memory TTL+LRU per uvicorn worker. Same review-set / same agent
# fingerprint within TTL → no second LLM call. For multi-instance prod
# we'd swap the implementation for Redis behind the same get/set surface;
# callers don't need to change.
GEMINI_CACHE_MAX_SIZE=
GEMINI_CACHE_TTL_SECONDS=

# --- Future / not yet wired ---
LANGGRAPH_TRACING=false
