# Thundrly backend configuration.
# Copy to `.env` and fill in for local overrides; nothing in this file is
# required for the default SQLite-backed dev setup.

# --- Database ---
# Default: file-based SQLite at app/data/observations.db (no setup needed).
# For Postgres in prod:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/thundrly
DATABASE_URL=

# --- CORS ---
# Comma-separated list. Defaults to localhost:3000 + 127.0.0.1:3000.
# chrome-extension://* is always allowed via regex.
ALLOWED_ORIGINS=

# --- Rate limiting (slowapi) ---
# Default: in-memory (single-instance only).
# For multi-instance, use Redis:
#   RATELIMIT_STORAGE_URI=redis://localhost:6379
RATELIMIT_STORAGE_URI=

# --- LLM provider ---
# Preferred: OpenRouter. With OPENROUTER_API_KEY set, the backend calls
# google/gemini-2.5-flash through OpenRouter's OpenAI-compatible API.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Thundrly
LLM_PROVIDER=auto

# Legacy direct-Gemini fallback. Without either key the review_agent and
# decision_agent use deterministic heuristic paths.
#   Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default: gemini-2.5-flash.
GEMINI_MODEL=

# --- Gemini response cache ---
# In-memory TTL+LRU per uvicorn worker. Same review-set / same agent
# fingerprint within TTL → no second LLM call. For multi-instance prod
# we'd swap the implementation for Redis behind the same get/set surface;
# callers don't need to change.
GEMINI_CACHE_MAX_SIZE=
GEMINI_CACHE_TTL_SECONDS=

# --- External price comparison ---
# Best-effort current-market comparison via Bing Shopping. This replaces
# relying solely on Akakce/Cimri-style pages that often return bot checks.
EXTERNAL_PRICE_COMPARISON_ENABLED=1
EXTERNAL_PRICE_COMPARISON_TIMEOUT=6.0
EXTERNAL_PRICE_HISTORY_ENABLED=0

# --- Future / not yet wired ---
LANGGRAPH_TRACING=false
