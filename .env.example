# Production compose secrets. Copy to `.env` on the server and fill in.
# `.env` is gitignored — do NOT commit real values.

# --- Postgres ---
# Generated once at provisioning. 32+ chars, alphanumeric. Used by both
# postgres init and backend's DATABASE_URL.
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# --- LLM (optional) ---
# Preferred: OpenRouter. The backend uses google/gemini-2.5-flash by default.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://thundrly.com
OPENROUTER_APP_TITLE=Thundrly
LLM_PROVIDER=auto

# Legacy direct-Gemini fallback. Without either key, review_agent +
# decision_agent use deterministic fallback paths.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CACHE_TTL_SECONDS=900

# --- External price comparison ---
EXTERNAL_PRICE_COMPARISON_ENABLED=1
# Legacy Akakce history scrape is disabled by default; it often hits bot checks.
EXTERNAL_PRICE_HISTORY_ENABLED=0
